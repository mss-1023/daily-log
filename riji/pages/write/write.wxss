.write-page { padding-bottom: 40px; }

.char-count { text-align: right; font-size: var(--font-xs); color: var(--color-text-muted); }

.action-bar { display: flex; padding: 0 var(--spacing-md); margin-top: var(--spacing-lg); }
.btn-save { width: 100%; }

/* Inlined from /components/tag-input/tag-input.wxss */
.tag-input { padding: 0; }
.tag-input-label { font-size: var(--font-sm); color: var(--color-text-muted); margin-bottom: var(--spacing-sm); }
.tag-list { display: flex; flex-wrap: wrap; gap: var(--spacing-sm); margin-bottom: var(--spacing-md); min-height: 24px; }
.preset-list { padding: var(--spacing-sm) 0; }
.preset-grid { display: flex; flex-wrap: wrap; gap: var(--spacing-sm); margin-bottom: var(--spacing-md); }
.preset-item { padding: var(--spacing-xs) var(--spacing-md); border-radius: var(--radius-lg); border: 1px solid var(--color-border); font-size: var(--font-sm); color: var(--color-text-secondary); transition: all 0.15s ease; }
.preset-item.active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

.custom-tag-input { display: block; padding: 10px 12px; background: var(--color-bg); border-radius: 6px; font-size: 14px; color: var(--color-text); margin-top: 8px; }

.tag { display: inline-block; background: var(--color-highlight); color: var(--color-primary); font-size: var(--font-xs); padding: 2px 8px; border-radius: var(--radius-sm); }
.tag-removable { padding-right: 4px; }
.preset-label { font-size: var(--font-sm); color: var(--color-text-muted); padding: var(--spacing-sm) 0; }
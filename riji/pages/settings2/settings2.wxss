.page { padding: 0 0 80px; }
.storage-row { font-size: 12px; color: var(--color-text-muted); margin-bottom: 8px; }
.setting-list { padding: 0; }
.setting-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; border-bottom: 1px solid var(--color-border); font-size: 15px; color: var(--color-text); }
.setting-row:last-child { border-bottom: none; }
.setting-row.danger { color: var(--color-danger); }
.arrow { color: var(--color-text-muted); font-size: 18px; }
.about-content { display: flex; flex-direction: column; gap: 8px; font-size: 13px; color: var(--color-text-secondary); text-align: left; margin: 12px 0; }

.mine-page {
  padding-bottom: 60px;
}

/* ── User Header (compact) ── */

.user-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-lg);
  background: var(--color-card);
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}
.header-settings { margin-left: auto; font-size: 22px; padding: 4px; }

.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--color-highlight);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}

.user-greeting-block {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.user-greeting {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}

.user-date {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  line-height: 1.3;
}

/* ── Backup Tip ── */

.backup-tip {
  background: var(--color-warning);
  color: #fff;
  padding: var(--spacing-sm) var(--spacing-lg);
  font-size: var(--font-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin: 0 var(--spacing-lg) var(--spacing-sm);
  border-radius: var(--radius-sm);
}

.backup-tip-icon {
  font-size: 16px;
  flex-shrink: 0;
}

/* ── Stats Cards ── */

.stats-row {
  display: flex;
  padding: var(--spacing-md) var(--spacing-lg);
  gap: var(--spacing-sm);
}

.stat-card {
  flex: 1;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-sm);
  text-align: center;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.stat-icon {
  font-size: 22px;
  margin-bottom: 2px;
}

.stat-value {
  font-size: 24px;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-top: 2px;
}

/* ── Quick Tools Grid ── */

.tools-grid {
  display: flex;
  flex-wrap: wrap;
  padding: var(--spacing-md) var(--spacing-lg);
  gap: var(--spacing-sm);
}

.tool-card {
  width: calc((100% - 2 * var(--spacing-sm)) / 3);
  background: var(--color-card);
  border-radius: 12px;
  padding: 12px 8px;
  text-align: center;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  transition: all 0.15s ease;
  box-sizing: border-box;
}

.tool-card:active {
  background: var(--color-highlight);
  transform: scale(0.95);
}

.tool-icon {
  font-size: 24px;
  line-height: 1;
}

.tool-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1;
}


.page { padding-bottom: 80px; }

.date-header { background: linear-gradient(135deg, #2c3e3e, #3d5454); padding: var(--spacing-lg); border-radius: 0 0 var(--radius-lg) var(--radius-lg); box-shadow: var(--shadow-md); margin-bottom: var(--spacing-sm); position: relative; }
.avatar-btn { position: absolute; left: var(--spacing-lg); top: 50%; transform: translateY(-50%); font-size: 24px; opacity: 0.8; }
.date-header .arrow { color: #fff; font-size: 24px; }
.date-header .date-text { color: #fff; }
.date-header .weekday { color: rgba(255,255,255,0.7); }
.date-info { display: flex; flex-direction: column; align-items: center; }

.quote-card { margin: 0 var(--spacing-lg); padding: var(--spacing-md); background: var(--color-highlight); border-radius: var(--radius-md); text-align: center; }
.quote-text { font-size: var(--font-sm); color: var(--color-text-secondary); font-style: italic; }

.mood-card { margin: 0 var(--spacing-lg); padding: var(--spacing-md); background: var(--color-card); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
.mood-row { display: flex; justify-content: space-around; align-items: center; }
.mood-item { display: flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: 50%; background: var(--color-bg); transition: transform 0.15s ease; }
.mood-emoji { font-size: 26px; }
.mood-selected { transform: scale(1.18); background: var(--color-highlight); box-shadow: var(--shadow-md); }

.habit-list { padding: 0 var(--spacing-lg); }
.habit-item { display: flex; align-items: center; padding: var(--spacing-sm); margin-bottom: var(--spacing-xs); border-radius: var(--radius-sm); border-left: 4px solid var(--color-primary); background: var(--color-card); box-shadow: var(--shadow-sm); }
.habit-check { font-size: 18px; margin-right: var(--spacing-sm); }
.habit-icon { margin-right: var(--spacing-xs); }
.habit-name { font-size: var(--font-md); flex: 1; }
.habit-done { border-left-color: var(--color-success); background: var(--color-highlight); }
.habit-done .habit-name { text-decoration: line-through; color: var(--color-text-muted); }

.entry-card { border-top: 3px solid var(--color-primary); }
.content-display { white-space: pre-wrap; word-break: break-all; font-size: var(--font-md); line-height: 1.8; margin-bottom: var(--spacing-sm); }
.tag-row { display: flex; flex-wrap: wrap; gap: var(--spacing-xs); margin-bottom: var(--spacing-sm); }
.tag { display: inline-block; background: var(--color-highlight); color: var(--color-primary); font-size: var(--font-xs); padding: 2px 8px; border-radius: 20px; }
.entry-footer { display: flex; align-items: center; justify-content: space-between; margin-top: var(--spacing-md); padding-top: var(--spacing-sm); border-top: 1px solid var(--color-border); }
.char-count { font-size: var(--font-xs); color: var(--color-text-muted); }

.todo-list { padding: var(--spacing-sm) 0; }
.todo-row { display: flex; align-items: center; gap: var(--spacing-md); padding: var(--spacing-md); border-bottom: 1px solid var(--color-border); }
.todo-row:last-child { border-bottom: none; }
.todo-check { font-size: 22px; width: 28px; text-align: center; flex-shrink: 0; }
.todo-title { flex: 1; font-size: var(--font-md); }
.todo-deadline { font-size: var(--font-xs); color: var(--color-text-muted); background: var(--color-bg); padding: 2px 8px; border-radius: var(--radius-sm); flex-shrink: 0; }
.todo-more { text-align: center; padding: var(--spacing-sm) 0; font-size: var(--font-sm); color: var(--color-primary); }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 30px 20px; color: var(--color-text-muted); }
.empty-icon { font-size: 48px; margin-bottom: var(--spacing-sm); opacity: 0.55; }
.empty-text { font-size: var(--font-md); opacity: 0.65; }
.memorial-page { padding-bottom: 80px; }
.memorial-card { display: flex; align-items: center; margin: 4px 16px; padding: 16px; gap: 12px; }
.memorial-type-icon { font-size: 28px; flex-shrink: 0; }
.memorial-body { flex: 1; }
.memorial-title { font-size: 16px; font-weight: 500; color: var(--color-text); }
.memorial-date { font-size: 12px; color: var(--color-text-muted); margin-top: 2px; }
.memorial-note { font-size: 12px; color: var(--color-text-muted); margin-top: 2px; }
.countdown-badge { padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: 500; flex-shrink: 0; }
.countdown-badge.today { background: var(--color-danger); color: #fff; }
.countdown-badge.upcoming { background: var(--color-highlight); color: var(--color-primary); }
.countdown-badge.past { background: var(--color-bg); color: var(--color-text-muted); }
.type-picker { display: flex; gap: 8px; }
.type-option { padding: 8px; border-radius: 8px; border: 2px solid var(--color-border); font-size: 20px; }
.type-option.active { border-color: var(--color-primary); background: var(--color-highlight); }

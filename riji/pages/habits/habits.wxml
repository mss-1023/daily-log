<view class="page">
  <view class="section-title">习惯管理</view>

  <view wx:if="{{habits.length === 0}}" class="empty-state">
    <text class="empty-icon">🌟</text>
    <text class="empty-text">暂无习惯</text>
  </view>

  <view wx:for="{{habits}}" wx:key="id" class="habit-row">
    <view class="habit-info">
      <text class="habit-icon">{{item.icon}}</text>
      <text class="habit-name">{{item.name}}</text>
    </view>
    <view class="habit-btns">
      <text class="habit-edit" data-habit="{{item}}" bindtap="onEdit">✏️</text>
      <text class="habit-del" data-habit="{{item}}" bindtap="onDeleteConfirm">🗑️</text>
    </view>
  </view>

  <view class="add-btn" bindtap="onAdd">+ 添加习惯</view>

  <view wx:if="{{showPopup}}" class="popup-mask" bindtap="onClosePopup">
    <view class="popup-form" catchtap="noop">
      <view class="popup-title">{{editingHabit ? '编辑' : '添加'}}</view>
      <view class="form-label">名称</view>
      <input class="form-input" value="{{formName}}" placeholder="输入习惯名称" bindinput="onNameInput"/>
      <view class="form-label">图标</view>
      <view class="icon-grid">
        <view wx:for="{{habitIcons}}" wx:key="*this" class="icon-item {{formIcon === item ? 'sel' : ''}}" data-icon="{{item}}" bindtap="onPickIcon">{{item}}</view>
      </view>
      <view class="form-actions">
        <button class="btn-cancel" bindtap="onClosePopup">取消</button>
        <button class="btn-save" bindtap="onSave">保存</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showDeleteDialog}}" class="popup-mask" bindtap="onCancelDelete">
    <view class="dialog-box" catchtap="noop">
      <text class="dialog-title">确认删除？</text>
      <view class="dialog-actions">
        <button class="btn-cancel" bindtap="onCancelDelete">取消</button>
        <button class="btn-delete" bindtap="onConfirmDelete">删除</button>
      </view>
    </view>
  </view>
</view>

.page { padding-bottom: 80px; }
.stats-card { margin: 16px; border-radius: 16px; padding: 20px; background: var(--color-card); box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
.month-nav { display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 8px; }
.month-arrow { font-size: 20px; color: var(--color-primary); padding: 4px 8px; }
.month-label { font-size: 15px; font-weight: 500; color: var(--color-text); }
.stats-main { text-align: center; margin-bottom: 12px; }
.stats-amount { font-size: 36px; font-weight: 800; color: var(--color-primary); display: block; margin-top: 4px; letter-spacing: -1px; }
.stats-cats { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
.cat-stat { display: flex; align-items: center; gap: 4px; background: var(--color-bg); padding: 4px 10px; border-radius: 16px; }
.cat-stat-emoji { font-size: 16px; }
.cat-stat-amount { font-size: 12px; color: var(--color-text-secondary); font-weight: 500; }
.date-group { margin: 4px 16px 12px; }
.date-group-header { font-size: 13px; color: var(--color-text-muted); padding: 10px 0 6px; font-weight: 500; border-bottom: 1px dashed var(--color-border); margin-bottom: 6px; }
.record-item { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--color-border); }
.record-item:last-child { border-bottom: none; }
.record-emoji { width: 36px; height: 36px; border-radius: 10px; background: var(--color-bg); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.record-body { flex: 1; min-width: 0; }
.record-category { font-size: 14px; font-weight: 500; color: var(--color-text); }
.record-note { font-size: 12px; color: var(--color-text-muted); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-top: 1px; }
.record-amount { font-size: 15px; font-weight: 600; color: var(--color-danger); flex-shrink: 0; }
.cat-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 4px; }
.cat-item { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: 8px 10px; border-radius: 10px; border: 2px solid var(--color-border); background: var(--color-card); }
.cat-item.active { border-color: var(--color-primary); background: var(--color-highlight); }
.cat-emoji { font-size: 20px; }
.cat-name { font-size: 11px; color: var(--color-text-muted); }

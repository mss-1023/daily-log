.body-page { padding-bottom: 80px; }
.section-title { font-size: 14px; color: var(--color-text-muted); padding: 12px 16px 8px; }
.weight-log-list { margin: 0 16px; background: var(--color-card); border-radius: 8px; padding: 12px 16px; }
.weight-log-item { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--color-border); }
.weight-log-item:last-child { border-bottom: none; }
.weight-log-left { display: flex; gap: 8px; align-items: baseline; }
.weight-log-date { font-size: 12px; color: var(--color-text-muted); }
.weight-log-kg { font-size: 16px; font-weight: 600; color: var(--color-primary); }
.weight-log-right { display: flex; gap: 8px; align-items: center; font-size: 14px; }
.weight-log-empty { padding: 16px; text-align: center; font-size: 14px; color: var(--color-text-muted); }
.date-group { margin: 8px 16px; }
.date-group-header { font-size: 12px; color: var(--color-text-muted); padding: 8px 0; }
.body-card { background: var(--color-card); border-radius: 8px; padding: 12px 16px; margin-bottom: 4px; }
.body-card-top { display: flex; align-items: center; gap: 16px; }
.weight-value { font-size: 24px; font-weight: 700; color: var(--color-primary); }
.weight-unit { font-size: 14px; color: var(--color-text-muted); }
.body-exercise { display: flex; align-items: center; gap: 8px; flex: 1; }
.exer-emoji { font-size: 20px; }
.exer-name { font-size: 14px; }
.exer-duration { font-size: 12px; color: var(--color-text-muted); margin-left: auto; }
.body-card-note { margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--color-border); font-size: 14px; color: var(--color-text-secondary); }
.exercise-picker { display: flex; gap: 8px; overflow-x: auto; }
.exer-option { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: 6px 8px; border-radius: 8px; border: 2px solid var(--color-border); flex-shrink: 0; }
.exer-option.exer-active { border-color: var(--color-primary); background: var(--color-highlight); }
.exer-option-emoji { font-size: 20px; }
.exer-option-name { font-size: 11px; color: var(--color-text-muted); }
.weight-input-wrap { display: flex; align-items: center; background: var(--color-bg); border-radius: 6px; padding: 0 12px; }
.weight-input { flex: 1; padding: 10px 0; font-size: 18px; font-weight: 600; }
.weight-input-unit { font-size: 14px; color: var(--color-text-muted); }
.duration-input-wrap { display: flex; align-items: center; background: var(--color-bg); border-radius: 6px; padding: 0 12px; }
.duration-input { flex: 1; padding: 10px 0; font-size: 18px; font-weight: 600; }
.duration-input-unit { font-size: 14px; color: var(--color-text-muted); }
.note-input-wrap { background: var(--color-bg); border-radius: 6px; padding: 0 12px; height: 44px; display: flex; align-items: center; }
.note-input { flex: 1; font-size: 14px; height: 44px; }
.date-picker-btn { padding: 10px 12px; background: var(--color-bg); border-radius: 6px; font-size: 14px; }

.page { padding-bottom: 80px; }
.section { margin: 8px 16px; background: var(--color-card); border-radius: 12px; overflow: hidden; }
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; }
.section-header text { font-size: 15px; font-weight: 600; color: var(--color-text); }
.section-count { font-size: 12px; color: var(--color-text-muted); font-weight: 400; margin-left: 4px; }
.arrow { font-size: 14px; color: var(--color-text-muted); transition: transform 0.2s; display: inline-block; }
.arrow.open { transform: rotate(90deg); }
.section-empty { padding: 20px; text-align: center; font-size: 13px; color: var(--color-text-muted); }
.section-add { padding: 10px; text-align: center; font-size: 13px; color: var(--color-primary); border-top: 1px solid var(--color-border); }
.list-item { display: flex; align-items: center; gap: 10px; padding: 10px 16px; border-top: 1px solid var(--color-border); }
.checkbox { width: 20px; height: 20px; border: 2px solid var(--color-border); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: transparent; flex-shrink: 0; }
.checkbox.checked { background: var(--color-success); border-color: var(--color-success); color: #fff; }
.item-body { flex: 1; min-width: 0; }
.item-title { font-size: 14px; color: var(--color-text); display: block; }
.item-title.done { text-decoration: line-through; color: var(--color-text-muted); }
.item-meta { font-size: 11px; color: var(--color-text-muted); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-top: 2px; }
.item-del { font-size: 14px; flex-shrink: 0; padding: 4px; opacity: 0.5; }
.cat-row { display: flex; gap: 8px; margin-bottom: 8px; }
.cat-item { padding: 8px; border-radius: 8px; border: 2px solid var(--color-border); font-size: 20px; }
.cat-item.active { border-color: var(--color-primary); background: var(--color-highlight); }
.wish-page { padding-bottom: 80px; }
.wish-card { display: flex; align-items: center; justify-content: space-between; margin: 4px 16px; padding: 16px; }
.wish-card-left { display: flex; align-items: flex-start; flex: 1; }
.wish-priority-dot { width: 10px; height: 10px; border-radius: 50%; margin-top: 6px; margin-right: 12px; flex-shrink: 0; }
.wish-body { flex: 1; }
.wish-title { font-size: 16px; color: var(--color-text); }
.wish-title.done { text-decoration: line-through; color: var(--color-text-muted); }
.wish-description { font-size: 12px; color: var(--color-text-muted); margin-top: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wish-checkbox { width: 22px; height: 22px; border: 2px solid var(--color-border); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; color: transparent; }
.wish-checkbox.checked { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
.segmented-control { display: flex; background: var(--color-bg); border-radius: 8px; padding: 3px; }
.segment { flex: 1; text-align: center; padding: 8px 0; font-size: 14px; color: var(--color-text-muted); border-radius: 6px; }
.segment.active { background: var(--color-card); color: var(--color-primary); font-weight: 600; }
.toggle-row { display: flex; align-items: center; gap: 12px; }
.toggle-label { font-size: 14px; color: var(--color-text-secondary); }
